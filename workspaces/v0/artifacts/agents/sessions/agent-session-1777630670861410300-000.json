    "success_experiences": [
      {
        "version": "v0.1.43",
        "text": "候选版本生成完成后仍需通过验证与提升流程才能成为当前版本。"
      },
      {
        "version": "v0.1.42",
        "text": "v0.1.42 让多 AI 协作任务板从“能领取任务”推进到“能从中断领取中恢复”。租约机制保持轻量，只处理任务所有权过期和恢复，不引入复杂调度器，符合当前阶段稳定优先的策略。"
      },
      {
        "version": "v0.1.41",
        "text": "v0.1.41 建立了多 AI 同步修改代码的最小协调层。它不直接启动真实并发 AI 执行器，而是先把并发协作中最关键的事实来源、写入范围、依赖关系、领取状态和提示词边界持久化，符合受控自进化的安全顺序。"
      },
      {
        "version": "v0.1.40",
        "text": "v0.1.40 将记忆系统从“单文件持续追加”推进到“热记忆加冷归档”的结构，既保留审计追溯能力，又降低默认 AI 上下文读取成本。自动压缩接入 `agent-evolve` 后，后续进化不会继续让热记忆无限增长。"
      },
      {
        "version": "v0.1.39",
        "text": "v0.1.39 让 Agent 会话从“记录计划和工具”推进到“可以执行下一步计划”，自我迭代闭环更进一步。系统仍保持克制：需要外部输入的 Runtime 和 AI 工具不会自动猜测输入，而是明确阻断或要求调用方提供。"
      }
    ],
    "failure_experiences": [
      {
        "version": "v0.1.41",
        "text": "测试阶段发现一个已解决问题：领取提示词生成时仍可领取任务列表包含当前已领取任务，可能诱导多线程重复处理；已在提示词生成阶段排除当前任务，并让释放后的任务恢复为候选任务提示词，新增测试验证。本轮没有未解决错误。"
      },
      {
        "version": "v0.1.40",
        "text": "本轮没有未解决错误。并行执行两个 `cargo run` 时出现 Cargo 文件锁等待提示，命令最终成功，不构成系统错误。"
      },
      {
        "version": "v0.1.39",
        "text": "本轮没有未解决错误。开发阶段 `cargo fmt --check` 提示 rustfmt 排版调整，已运行 `cargo fmt` 并复验通过。"
      }
    ],
    "optimization_suggestions": [
      {
        "version": "v0.1.43",
        "text": "继续减少小版本碎片化文件和目录。"
      },
      {
        "version": "v0.1.42",
        "text": "下一步应把协作任务板和 Agent 会话步进器连接起来：会话开始时自动初始化任务板，执行前领取任务，步骤成功后完成任务，失败或阻断时释放任务，并将 Runtime 验证结果写回同一协作事件链。"
      },
      {
        "version": "v0.1.41",
        "text": "下一步应让 Agent 会话或自动进化流程在开始执行前自动创建协作队列，并把队列任务与 Agent 步进执行、Runtime 验证和最终归档串联起来。后续可增加超时租约、任务阻断状态、冲突人工审查和任务动态拆分。"
      },
      {
        "version": "v0.1.40",
        "text": "下一步应继续完善 Agent 多步自动执行，让系统在受控工具范围内自动推进多个计划步骤，并在遇到需要外部输入或验证失败时暂停、归档并给出清晰原因。"
      },
      {
        "version": "v0.1.39",
        "text": "下一步应实现受控的多步执行命令，让系统可以在安全工具范围内自动推进多个步骤，并在遇到 Runtime、AI 或错误阻断时暂停并生成可审计的待办。"
      }
    ],
    "reusable_experiences": [
      {
        "version": "v0.1.43",
        "text": "小版本记录应追加到 major 聚合文件，避免目录数量随 patch 增长。"
      },
      {
        "version": "v0.1.42",
        "text": "多 AI 协作必须同时管理“任务是否有人做”和“领取是否仍有效”。租约过期不应直接删除任务，而应恢复为待领取、保留事件和原因，确保后续线程可以基于同一事实来源继续工作。"
      },
      {
        "version": "v0.1.41",
        "text": "多 AI 并行写代码前，必须先持久化任务所有权和写入范围。提示词不能只描述能力，还必须描述边界、禁止事项、完成命令和释放命令；否则多个线程很容易重复做同一个任务或覆盖彼此改动。"
      },
      {
        "version": "v0.1.40",
        "text": "记忆读取和记忆压缩要分离：默认读取只访问热记忆，冷归档只服务审计和复盘。进化流程中的维护动作应放在应用用例层，由 `agent-evolve` 统一编排，避免 CLI 或 Agent 业务逻辑各自实现一套规则。"
      },
      {
        "version": "v0.1.39",
        "text": "自动执行必须以会话中的待执行步骤为唯一来源，不能重新推断计划；缺少必要输入时保持步骤待执行，比伪造成功结果更安全。"
      }
    ]
  },
