    "success_experiences": [
      {
        "version": "v0.1.38",
        "text": "v0.1.38 将 Agent Tool 从“可配置、可绑定”推进到“可调用、可校验、可审计”，代码边界更清晰：工具定义在 Agent 模块，工具执行在应用用例层，CLI 不承载业务逻辑。这让后续多 Agent 自动执行计划具备了稳定入口。"
      },
      {
        "version": "v0.1.37",
        "text": "v0.1.37 建立了 Agent Tool 的可插拔配置基础，Agent 计划从“按能力分工”进一步扩展为“按能力和工具组合执行”，为后续真实工具执行、AI 工具接入和多 Agent 编排打下了可维护边界。"
      },
      {
        "version": "v0.1.36",
        "text": "v0.1.36 让 Agent 会话不仅保存计划和执行结果，还保存计划依据，计划、记忆、执行和审计之间的连接更完整。"
      },
      {
        "version": "v0.1.35",
        "text": "v0.1.35 让 Agent 计划阶段真实消费历史记忆经验，计划输出从静态步骤扩展为带上下文证据的协作计划，进一步接近自动进化流程的可解释闭环。"
      },
      {
        "version": "v0.1.34",
        "text": "v0.1.34 将记忆系统从读取推进到结构化提取，后续 Agent 计划可以直接消费历史经验，向自动生成计划更近一步。"
      }
    ],
    "failure_experiences": [
      {
        "version": "v0.1.38",
        "text": "测试阶段发现两个已解决问题：版本提升后 3 个测试断言仍停留在旧的下一个期望版本，已修正为 `v0.1.40` 或 `v0.1.41`；真实 CLI Runtime 工具验证时，首次 PowerShell 正则未能解析会话编号，已改用直接匹配会话标识并复验通过。本轮没有未解决错误。"
      },
      {
        "version": "v0.1.37",
        "text": "测试阶段发现机械版本替换误改了 `Cargo.lock` 中依赖 `tracing-core` 的版本号，已恢复依赖版本并复验通过。动态配置测试初版未创建父目录，已补齐夹具目录创建。本轮没有未解决错误。"
      },
      {
        "version": "v0.1.36",
        "text": "测试阶段发现初始化记忆归档可能为空白可读但没有可提取的小节，已通过显式测试夹具修正断言。本轮没有未解决错误。"
      }
    ],
    "optimization_suggestions": [
      {
        "version": "v0.1.38",
        "text": "下一步应实现 Agent 执行计划的自动步进器，让会话可以按计划步骤自动选择工具、执行工具、记录结果，并在失败时自动转入错误归档和回滚流程。"
      },
      {
        "version": "v0.1.37",
        "text": "下一步应实现工具执行协议，让工具定义不仅能进入计划，还能由 Agent 步骤通过统一接口调用 Runtime、AI 请求、记忆读取和归档能力。"
      },
      {
        "version": "v0.1.36",
        "text": "下一步应让自动进化流程在候选验证前自动执行一组受控验证命令，并把 Runtime 运行证据绑定到同一 Agent 会话中。"
      },
      {
        "version": "v0.1.35",
        "text": "下一步应让 Agent 会话在执行计划时引用 `agent-plan` 的结构化经验摘要，并逐步把 AI 提供商能力接入规划 Agent，而不是直接写入 CLI。"
      },
      {
        "version": "v0.1.34",
        "text": "下一步可将 `memory-insights` 的结果注入 `agent-plan` 输出，让计划命令显式展示历史经验如何影响步骤设计。"
      }
    ],
    "reusable_experiences": [
      {
        "version": "v0.1.38",
        "text": "工具执行必须先校验 Agent 绑定，再校验输入类型；自定义工具没有执行器时要显式失败。版本提升后，涉及“下一个候选版本”的测试断言需要按语义重新计算，不能只做机械替换。"
      },
      {
        "version": "v0.1.37",
        "text": "动态配置必须先做结构化验证，再进入计划；工具绑定结果应写入计划和会话，避免执行阶段重新推断导致审计不一致。"
      },
      {
        "version": "v0.1.36",
        "text": "会话文件中的历史依据应保存为摘要和引用，避免复制完整记忆正文；新增字段必须使用可选结构并提供旧文件兼容测试。"
      },
      {
        "version": "v0.1.35",
        "text": "计划上下文应通过应用层统一报告传递；CLI 只做参数解析和展示，可以避免未来真实多 Agent 执行时出现第二套记忆读取逻辑。"
      },
      {
        "version": "v0.1.34",
        "text": "历史经验提取应保持只读、可重复、可测试；先生成结构化视图，再接入计划和执行流程，可以避免直接改写记忆造成审计混乱。"
      }
    ]
